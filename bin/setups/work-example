SSH_HOST="ssh-desktop"

list-jobs() {
    echo "override this with your job listing command"
}

setup() {
    work --host $SSH_HOST

    sleep 2
    (
        ws pkg1 
        ws pkg2
        wait
    )
}

if [ -z $1 ]; then
    setup
else
    $@
fi
